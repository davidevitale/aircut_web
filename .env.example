# --- Firebase (single source of truth, condivisa con l'app mobile) ---
# Config pubblica del client (dalla console Firebase > Impostazioni progetto)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Service account (Admin SDK) — SOLO server. Mai esporre al client.
# Incollare l'intero JSON del service account su una riga, oppure usare le 3 var sotto.
FIREBASE_SERVICE_ACCOUNT_JSON=
# In alternativa al JSON completo:
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=          # con \n al posto degli a-capo

# --- Stripe ---
STRIPE_SECRET_KEY=                # SOLO server
STRIPE_WEBHOOK_SECRET=            # SOLO server (verifica firma webhook)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=                  # price ricorrente €29/mese (EUR)

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- (Opzionale) OTP via SMS gestito da Firebase Phone Auth (reCAPTCHA) ---
