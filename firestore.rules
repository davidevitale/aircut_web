rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // profiles/{uid}: il professionista. Stessa collezione letta dall'app mobile.
    match /profiles/{uid} {

      // L'utente legge SOLO il proprio profilo.
      allow read: if request.auth != null && request.auth.uid == uid;

      // L'utente puo aggiornare SOLO i propri dati anagrafici.
      // I campi di billing e di trial sono immutabili dal client:
      // li scrive solo il server (Admin SDK, che bypassa queste rules).
      allow update: if request.auth != null
        && request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny([
                'subscription_status',
                'trial_started_at',
                'trial_ends_at',
                'stripe_customer_id',
                'stripe_subscription_id',
                'current_period_end',
                'created_at',
                'nickname',
                'nickname_key'
              ]);

      // Creazione e modifiche al billing: solo server (Admin SDK).
      allow create, delete: if false;
    }

    // nicknames/{key}: indice di univocità @nick -> uid.
    // Lettura libera (l'app risolve @nick in profilo pubblico).
    // Scrittura SOLO server (Admin SDK): il nickname si riserva al signup.
    match /nicknames/{key} {
      allow read: if true;
      allow write: if false;
    }
  }
}
